# PackNGo Admin Panel — Security
Options -Indexes

# Allow ONLY index.php (the admin panel entry point)
<Files "index.php">
    Order allow,deny
    Allow from all
</Files>

# Block everything else in this folder
<FilesMatch "^(?!index\.php$)">
    Order allow,deny
    Deny from all
</FilesMatch>

# No caching of admin panel
<IfModule mod_headers.c>
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
</IfModule>
